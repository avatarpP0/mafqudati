// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model LostItem {
  id                    String    @id @default(cuid())
  title                 String
  description           String
  category              String
  location              String
  dateFound             DateTime
  imageUrl              String?
  contactName           String
  contactPhone          String
  status                String    @default("found")
  verificationQuestion  String?
  verificationAnswer    String?
  reward                String?
  latitude              Float?
  longitude             Float?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  reports               Report[]
  favorites             Favorite[]
}

model LostReport {
  id           String    @id @default(cuid())
  title        String
  description  String
  category     String
  location     String
  dateLost     DateTime
  contactName  String
  contactPhone String
  reward       String?
  status       String    @default("active")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  reports      Report[]
  favorites    Favorite[]
}

model Report {
  id          String   @id @default(cuid())
  itemType    String   // "lostItem" or "lostReport"
  itemId      String
  reason      String   // "fake", "inappropriate", "wrong_info", "other"
  details     String?
  createdAt   DateTime @default(now())
  lostItem    LostItem? @relation(fields: [itemId], references: [id])
  lostReport  LostReport? @relation(fields: [itemId], references: [id])
}

model Favorite {
  id          String   @id @default(cuid())
  itemType    String   // "lostItem" or "lostReport"
  itemId      String
  sessionId   String   // Browser session/fingerprint for anonymous users
  createdAt   DateTime @default(now())
  lostItem    LostItem? @relation(fields: [itemId], references: [id])
  lostReport  LostReport? @relation(fields: [itemId], references: [id])

  @@unique([itemType, itemId, sessionId])
}
